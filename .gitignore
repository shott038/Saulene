node_modules/
dist/
# The plugin's bundled dist IS shipped — Claude Code runs it as-is with no build
# step on the user's machine. Track ONLY this dist; every other dist/ stays ignored.
!packages/plugin/dist/
!packages/plugin/dist/**
*.tsbuildinfo
.DS_Store
coverage/
*.log

# Local soul data must never be committed
.saulene/
*.soul.json

# Live harness-run artifacts (real LLM judge) — non-deterministic, paid; never committed
.judge-cache.json
.live-run.json
.live-run.log
# A/B behavioral-validation run artifacts (subscription) — non-deterministic; never committed
.ab-cache.json
.ab-run.json
.ab-run.log
# Salience-sweep run artifacts (subscription) — non-deterministic; never committed
.salience-run.json
.salience-run.log
# Max-contrast diagnostic run artifacts (subscription) — non-deterministic; never committed
.diagnostic-run.json
.diagnostic-run.log
# Identification-gradient run artifacts (subscription) — non-deterministic; never committed
.ident-run.json
.ident-run.log
# Pairwise 2-way discrimination run artifacts (subscription) — non-deterministic; never committed
.pairwise-run.json
.pairwise-run.log
.pairwise-emotional-run.json
.pairwise-emotional-run.log

# Local working context (not shared)
CLAUDE.md

# Feature worktrees (each tracks its own branch; never part of main's tree)
.claude/worktrees/

# viz-exploration scratch — verification screenshots & tooling artifacts
/*.png
.playwright-mcp/
docs/.playwright-mcp/
scripts/_tune.mjs
docs/_tune.html
# regenerable animation frame intermediates (rebuilt via ul-idle.mjs --export-*)
docs/ul-*-frames.json

# Generated lifecycle-visualizer output (regenerated via `pnpm demo:html`)
tools/demo/out/

# Scheduler lock (transient)
.claude/scheduled_tasks.lock

# per-worktree feature missions — never tracked on main
MISSION.md

# live-run caches (subscription model responses) — never tracked
.*cache*.json
*cache*.json
